# =============================================================================
# Mini Coze - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
PORT=3001

# -----------------------------------------------------------------------------
# LLM API 配置 (SiliconFlow)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3

# -----------------------------------------------------------------------------
# Embedding API 配置 (用于知识库向量检索)
# -----------------------------------------------------------------------------
# Embedding 服务提供商 (默认使用 SiliconFlow)
EMBEDDING_PROVIDER=siliconflow
# Embedding 模型 (推荐使用中文优化的模型)
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# API Key (如未设置则使用 DEEPSEEK_API_KEY)
EMBEDDING_API_KEY=${DEEPSEEK_API_KEY}
# API Base URL
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# 向量维度 (根据模型调整，bge-large-zh-v1.5 为 1024)
EMBEDDING_DIMENSIONS=1024

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
# SQLite (默认)
# DATABASE_PATH=mini-coze.db

# PostgreSQL (使用 Supabase 或其他托管服务)
DATABASE_URL=postgresql://user:password@host:port/database

# -----------------------------------------------------------------------------
# 运行环境
# -----------------------------------------------------------------------------
NODE_ENV=development
